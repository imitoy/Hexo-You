<style>
  @import url('/css/header-card.css');
</style>

<mdui-card variant="filled" class="header-card">
  <div class="header-title">Tags</div>
  <div class="header-content">All tags of the blog</div>
</mdui-card>

<div class="tags-container">
  <% site.tags.forEach(function(tag){ %>
    <mdui-chip rounded href="<%- url_for(tag.path) %>">
      <%= tag.name %>
      <mdui-icon src="/icon/tag.svg" slot="icon"></mdui-icon>
    </mdui-chip>
  <% }) %>
</div>

<script>
  const tags = document.querySelector('.navigation-drawer-list-tags');
  tags.active = true;
</script>